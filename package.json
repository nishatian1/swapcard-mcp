{
  "name": "swapcard-mcp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "MCP server exposing the Swapcard organizer API (Content + Analytics) as tools for Claude.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nishatian1/swapcard-mcp.git"
  },
  "keywords": ["mcp", "model-context-protocol", "swapcard", "graphql", "claude", "events"],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
