# --- Server ---
PORT=8090
# Public base URL where this server is reachable (used for OAuth metadata in Phase 4)
PUBLIC_BASE_URL=http://localhost:8090

# Secret used to sign/encrypt web session tokens (Phase 4). Generate: openssl rand -hex 32
TOKEN_ENCRYPTION_SECRET=

# OPTIONAL dev fallback: if set, used as the Swapcard key when a request carries none.
# In production the key comes from each request (Authorization header / web token), not from here.
SWAPCARD_API_KEY=
