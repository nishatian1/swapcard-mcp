# --- Server ---
PORT=8090
# Public base URL where this server is reachable (used to build OAuth metadata),
# e.g. https://mcp.example.com/swapcard
PUBLIC_BASE_URL=http://localhost:8090

# Secret used to sign/encrypt web session tokens. REQUIRED in production.
# Generate: openssl rand -hex 32
TOKEN_ENCRYPTION_SECRET=

# OPTIONAL dev fallback: if set, used as the Swapcard key when a request carries none.
# In production the key comes from each request (Authorization header / web token), not from here.
SWAPCARD_API_KEY=

# OPTIONAL: key used only for the upstream warm-up heartbeat that keeps the Swapcard
# connection hot (eliminates ~1.5s cold-start on the first call after idle). Recommended
# in production: set to the shared Swapcard key. If unset, warm-up pings unauthenticated.
WARMUP_API_KEY=
